<Page x:Class="nowayapopitka.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:nowayapopitka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Margin="10" x:Name="Sort" Grid.Row="0" Orientation="Horizontal">
            <TextBox Width="200" Height="25" x:Name="SearchBox" Margin="10,10,10,10" TextChanged="Update"/>
            <ComboBox x:Name="SortCombo" SelectionChanged="Update" Margin="10,10,10,10"  Width="200" Height="25">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="По складу: по возрастанию" />
                <ComboBoxItem Content="По складу: по убыванию" />
            </ComboBox>

            <ComboBox x:Name="FilterCombo" SelectionChanged="Update" Margin="10,10,10,10"  Width="200" Height="25"/>
        </WrapPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Grid.Row="1">
            <WrapPanel Orientation="Vertical" x:Name="Parent"/>
        </ScrollViewer>
        
       
    </Grid>
</Page>
