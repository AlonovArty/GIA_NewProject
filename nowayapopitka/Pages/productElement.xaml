<UserControl x:Class="nowayapopitka.Pages.productElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:nowayapopitka.Pages"
             mc:Ignorable="d" >
    <Grid Height="200" MinWidth="500">
        <Image Source="/Image/picture.png" Height="120" Width="120" x:Name="Photo" HorizontalAlignment="Left"/>

        <StackPanel Margin="200,10,100,10">
            <TextBlock Text="123" x:Name="tbArticle"/>
            <TextBlock Text="123" x:Name="tbName"/>
            <TextBlock Text="123" x:Name="tbDescription"/>
            <TextBlock Text="123" x:Name="tbPrice"/>
            <TextBlock Text="123" x:Name="tbAmount"/>
            <TextBlock Text="123" x:Name="tbCategory"/>
            <TextBlock Text="123" x:Name="tbUnit"/>
            <TextBlock Text="123" x:Name="tbManufacturer"/>
            <TextBlock Text="123" x:Name="tbProvider"/>
            
        </StackPanel>

        <TextBlock Text="123" VerticalAlignment="Center" HorizontalAlignment="Right" x:Name="tbDiscount"/>

        <StackPanel x:Name="Edits" VerticalAlignment="Bottom" HorizontalAlignment="Left" Orientation="Horizontal" Margin="10">
            <Button Content="Изменить" Click="EditProduct" Margin="0,0,10,0" Width="100" Height="25"/>
            <Button Content="Удалить" Click="DeleteProduct" Width="100" Height="25"/>
        </StackPanel>
    </Grid>
</UserControl>
